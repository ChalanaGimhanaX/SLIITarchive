{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "npm --prefix sliitui ci",
  "buildCommand": "bash build.sh",
  "outputDirectory": "sliitui/dist",
  "functions": {
    "api/**/*.py": {
      "maxDuration": 30,
      "excludeFiles": "{.git/**,.venv/**,.vercel-build-venv/**,backend/dev.sqlite3,backend/local.sqlite3,backend/test.sqlite3,backend/test-media/**,backend/media-local/**,docs/**,sliitui/node_modules/**,sliitui/dist/**}"
    }
  },
  "routes": [
    {
      "src": "/api",
      "dest": "/api/index.py"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/[...path].py"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
